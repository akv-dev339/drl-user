generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model admin {
  id       BigInt  @id @default(autoincrement())
  password String  @db.VarChar(255)
  role     String? @db.VarChar(255)
  username String  @unique(map: "UKgfn44sntic2k93auag97juyij") @db.VarChar(255)
}

model article {
  id            BigInt    @id @default(autoincrement())
  abstract_text String?   @db.VarChar(5000)
  authors       String?   @db.VarChar(255)
  created_at    DateTime? @db.DateTime(6)
  pages         String?   @db.VarChar(255)
  pdf_path      String?   @db.VarChar(255)
  slug          String?   @unique(map: "UKlc76j4bqg2jrk06np18eve5yj") @db.VarChar(255)
  title         String?   @db.VarChar(255)
  type          String?   @db.VarChar(255)
  volume_id     BigInt
  pdf_url       String?   @db.VarChar(255)
  article_type  String?   @db.VarChar(255)
  volume        volume    @relation(fields: [volume_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "FK5a12m1upcwr0d6746e9634bd2")

  @@index([volume_id], map: "FK5a12m1upcwr0d6746e9634bd2")
}

model journal {
  id         BigInt    @id @default(autoincrement())
  created_at DateTime? @db.DateTime(6)
  issn       String?   @db.VarChar(255)
  title      String    @db.VarChar(255)
  volume     volume[]
}

model lab_events {
  id          BigInt    @id @default(autoincrement())
  description String?   @db.VarChar(2000)
  event_date  DateTime? @db.Date
  image_url   String?   @db.VarChar(255)
  title       String?   @db.VarChar(255)
}

model lab_gallery {
  id          BigInt    @id @default(autoincrement())
  category    String?   @db.VarChar(255)
  image_url   String?   @db.VarChar(255)
  title       String?   @db.VarChar(255)
  uploaded_at DateTime? @db.DateTime(6)
}

model lab_mou {
  id                BigInt    @id @default(autoincrement())
  date_signed       DateTime? @db.Date
  description       String?   @db.VarChar(2000)
  document_url      String?   @db.VarChar(255)
  logo_url          String?   @db.VarChar(255)
  organization_name String?   @db.VarChar(255)
}

model lab_training {
  id          BigInt    @id @default(autoincrement())
  cost        Float?
  description String?   @db.VarChar(2000)
  duration    String?   @db.VarChar(255)
  end_date    DateTime? @db.Date
  image_url   String?   @db.VarChar(255)
  start_date  DateTime? @db.Date
  title       String?   @db.VarChar(255)
  trainer     String?   @db.VarChar(255)
}

model volume {
  id         BigInt    @id @default(autoincrement())
  created_at DateTime? @db.DateTime(6)
  is_current Boolean?  @db.Bit(1)
  title      String?   @db.VarChar(255)
  year       Int?
  journal_id BigInt
  article    article[]
  journal    journal   @relation(fields: [journal_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "FKps90t36gf0julth4mgsk8kdx7")

  @@index([journal_id], map: "FKps90t36gf0julth4mgsk8kdx7")
}
